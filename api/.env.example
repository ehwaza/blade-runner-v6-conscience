# Conseil des Remoras — Template cles API
# Copier en .env et remplir :
#   cp api/.env.example api/.env
#
# Ne jamais committer .env sur Git — protege par api/.gitignore

# Google Gemini
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# GROK xAI — optionnel, poids x2 si danger/piege/sent
GROK_API_KEY=

# Timer
REMORA_INTERVAL_SEC=300
REMORA_API_URL=http://localhost:8000
